gaps inner 10
smart_gaps off
gaps top 25
gaps outer 2

output HDMI-A-1 pos 0 0 res 1360x768
output eDP-1 pos -1360 0 res 1360x768

# set modifier keys
set $super Mod4
set $alt Mod1

# set font
font pango:Ionicons 9, Poppins 9

# use mouse + $super to drag floating windows
floating_modifier $super

# --- Autostart Applications ---
# Updated wallpaper to match i3 config 
exec --no-startup-id swaybg -m fill -i ~/wp5716349.jpg 
exec /usr/bin/pipewire
exec /usr/bin/pipewire-pulse
exec /usr/bin/wireplumber
exec mako
# Auto-lock after 5 minutes, turn off displays after 10
exec swayidle -w \
    timeout 300 'swaylock -f -i ~/.lock.png' \
    timeout 600 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    before-sleep 'swaylock -f -i ~/.lock.png'

# Added GVFS and Polkit from i3 config 
exec --no-startup-id /usr/lib/gvfs/gvfsd
exec --no-startup-id /usr/libexec/polkit-gnome-authentication-agent-1 &
exec --no-startup-id gvfsd &

# --- Keybinds ---
# start a terminal
bindsym $super+Return exec alacritty

# start fuzzel (kept per request) 
bindsym $super+d exec fuzzel

bindsym $super+Shift+c reload

# common apps keybinds
bindsym Print exec grim -g "$(slurp)" ~/Pictures/$(date +%Y-%m-%d_%H-%m-%s).png
bindsym $super+l exec swaylock \
    --image ~/.lock.png \
    --scaling fill \
    --ring-color f6a6aa \
    --key-hl-color 1c262c \
    --text-color f2d7d8
bindsym $super+w exec firefox
bindsym $super+e exec alacritty -e vifm

# Added new keybinds from i3 config 
bindsym $super+m exec alacritty -e ncmpcpp
bindsym $super+n exec mpv --player-operation-mode=pseudo-gui

# change volume and brightness
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

# kill focused window
bindsym $super+c kill
bindsym $alt+F4 kill

# focus and move binds (standardized)
bindsym $super+Left focus left
bindsym $super+Down focus down
bindsym $super+Up focus up
bindsym $super+Right focus right
bindsym $super+Shift+Left move left
bindsym $super+Shift+Down move down
bindsym $super+Shift+Up move up
bindsym $super+Shift+Right move right

# layout management
bindsym $super+h split h
bindsym $super+v split v
bindsym $super+s layout toggle split
bindsym $super+f fullscreen toggle
bindsym $super+space floating toggle
bindsym $super+Shift+space focus mode_toggle

# switch to workspace
bindsym $super+Control+Right workspace next
bindsym $super+Control+Left workspace prev
bindsym $super+1 workspace 1:I
bindsym $super+2 workspace 2:II
bindsym $super+3 workspace 3:III
bindsym $super+4 workspace 4:IV
bindsym $super+5 workspace 5:V
bindsym $super+6 workspace 6:VI

# move container to workspace
bindsym $super+Shift+1 move container to workspace 1:I
bindsym $super+Shift+2 move container to workspace 2:II
bindsym $super+Shift+3 move container to workspace 3:III
bindsym $super+Shift+4 move container to workspace 4:IV
bindsym $super+Shift+5 move container to workspace 5:V
bindsym $super+Shift+6 move container to workspace 6:VI

seat seat0 xcursor_theme capitaine-cursors 24
exec_always {
    gsettings set org.gnome.desktop.interface cursor-theme 'capitaine-cursors'
    gsettings set org.gnome.desktop.interface cursor-size 24
}
# restart and exit (Updated to swaynative commands)
bindsym $super+BackSpace exec "swaymsg reload"
bindsym $super+q exec "swaynag -t warning -m 'Really exit?' -b 'Yes' 'swaymsg exit'"

# resize mode
mode "resize" {
    bindsym Left resize shrink width 5 px or 5 ppt
    bindsym Down resize grow height 5 px or 5 ppt
    bindsym Up resize shrink height 5 px or 5 ppt
    bindsym Right resize grow width 5 px or 5 ppt
    bindsym Return mode "default"
}
bindsym $super+r mode "resize"

# class                 border  backgr. text    indic.  child_border
client.focused          #5a0000 #2d0000 #ffffff #800000 #5a0000
client.focused_inactive #957585 #957585 #ffffff #2e9ef4   #957585
client.unfocused        #353540 #353540 #888888 #292d2e   #353540
client.urgent           #ff4d4d #400000 #ffffff #ff4d4d #ff4d4d
client.placeholder      #002d2d #012b2b #88aaaa #002d2d #002d2d
client.background       #012b2b

# 1. Floating & Focus for Media and Archive Apps
# We use a regex for both app_id (Wayland) and class (XWayland)
for_window [app_id="(?i)eog|sxiv|feh|mpv|vlc|file-roller|xarchiver"] floating enable, focus
for_window [class="(?i)eog|sxiv|feh|mpv|vlc|file-roller|xarchiver"] floating enable, focus

# 2. Border Styling
# In Sway, "border pixel" is often written as "default_border"
default_border pixel 3
default_floating_border pixel 3

# 3. Handling Dialogs and Pop-ups
# Sway still supports window_role and window_type for XWayland apps
for_window [window_role="dialog"] floating enable
for_window [window_role="pop-up"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_type="menu"] floating enable

# Wayland-specific floating for common dialog types
for_window [app_id="thunar" title="File Operation Progress"] floating enable
# Target the specific replacement confirmation dialog
for_window [app_id="thunar" title="Confirm to replace files"] floating enable, sticky enable, focus
font pango: Courier Prime 11
workspace 1 output HDMI-A-1
workspace 2 output HDMI-A-1
workspace 3 output HDMI-A-1
workspace 4 output eDP-1

bar {
    swaybar_command waybar
    }


input "3823:49229:eGalax_Inc._eGalaxTouch_EXC3000-0367-46.00.00" {
    map_to_output eDP-1
    # If the touch is inverted or shifted, uncomment the line below:
    # calibration_matrix 1 0 0 0 1 0 0 0 1
}
